# Auto detect text files and normalize line endings
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Markdown / Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf

# Shell (must be LF)
*.sh text eol=lf
*.bash text eol=lf

# Batch (must be CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.db binary
*.sqlite binary
