{
  "hooks": [
    {
      "event": "SessionStart",
      "command": "python hooks/on_session_start.py",
      "timeout": 5000
    },
    {
      "event": "SessionEnd",
      "command": "python hooks/on_session_end.py",
      "timeout": 5000
    },
    {
      "event": "PreToolUse",
      "matcher": { "tool_name": "^(Write|Edit)$" },
      "command": "python hooks/on_pre_tool_use.py",
      "timeout": 3000
    }
  ]
}
